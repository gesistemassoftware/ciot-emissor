# Banco de dados. Sem essa variável, usa PGlite (Postgres embarcado em WASM)
# gravando em ./data/pglite — só serve para desenvolvimento local, não para
# produção (a cada instância/deploy do Vercel tem seu próprio filesystem).
# Em produção, aponte para um Postgres real (ex: Vercel Postgres / Neon):
# DATABASE_URL=postgres://usuario:senha@host:5432/banco
DATABASE_URL=

# Chave para criptografar em repouso o certificado e a senha de cada cliente
# (AES-256-GCM). Gere uma string aleatória forte (ex: openssl rand -hex 32).
# Obrigatório em produção — sem isso o sistema recusa iniciar aceitando
# certificados de clientes.
CERT_ENCRYPTION_KEY=

# Segredo usado para assinar o cookie de sessão (JWT). Gere uma string
# aleatória forte (ex: openssl rand -hex 32).
SESSION_SECRET=
