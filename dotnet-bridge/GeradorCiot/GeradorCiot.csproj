<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Ambiente=homologacao ou producao — escolhe qual DLL da ANTT é
         embutido no binário publicado (veja README.md). -->
    <Ambiente Condition="'$(Ambiente)' == ''">homologacao</Ambiente>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="GeradorCIOTShared">
      <HintPath>..\lib\$(Ambiente)\GeradorCIOTShared.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
